# ──────────────────────────────────────────────
# Lufora — Environment Variables
# ──────────────────────────────────────────────
# Copy this file to .env.local for local development.
# Set these same variables in Netlify Dashboard → Site → Environment Variables.
# ──────────────────────────────────────────────
#
# ✅ = Required for MVP deployment
# 🔜 = Future / optional (leave empty for now)
# ──────────────────────────────────────────────

# ─── DATABASE (✅ Required) ───
# Use Neon Postgres. Get a free database at https://neon.tech
#
# DATABASE_URL  → Pooled connection (used at runtime by Prisma Client)
#   Neon example: postgresql://user:pass@ep-xxx-pooler.us-east-2.aws.neon.tech/lufora?sslmode=require
#
# DIRECT_URL    → Non-pooled / direct connection (used by Prisma Migrate/Push)
#   Neon example: postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/lufora?sslmode=require
#
DATABASE_URL="postgresql://user:password@localhost:5432/lufora?schema=public"
DIRECT_URL="postgresql://user:password@localhost:5432/lufora?schema=public"

# ─── AUTH (✅ Required for production) ───
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="change-me-generate-a-real-secret"

# Local: http://localhost:3000
# Production: https://your-site.netlify.app (or your custom domain)
NEXTAUTH_URL="http://localhost:3000"

# Public app URL (used in meta tags, sharing, etc.)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ─── AUTH SECRET (NextAuth v5 uses AUTH_SECRET) ───
AUTH_SECRET="change-me-generate-a-real-secret"

# ─── IMAGE STORAGE — Cloudinary (🔜 Future) ───
# Required for production image uploads.
# Sign up at https://cloudinary.com (free tier available).
# Leave empty to use mock storage (placeholder images).
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# ─── IMAGE STORAGE — Supabase Storage (🔜 Alternative) ───
# Use instead of Cloudinary if preferred.
# SUPABASE_URL=""
# SUPABASE_ANON_KEY=""
# SUPABASE_STORAGE_BUCKET="plant-images"
